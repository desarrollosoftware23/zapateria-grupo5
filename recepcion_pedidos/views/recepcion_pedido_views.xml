<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista de formulario: pantalla principal para crear o editar un pedido -->
    <record id="view_recepcion_pedido_form" model="ir.ui.view">
        <field name="name">recepcion.pedido.form</field>
        <field name="model">recepcion.pedido</field>
        <field name="arch" type="xml">
            <form string="Recepción de Pedido">
                <header>
                    <button name="accion_recibir"
                            string="Marcar como recibido"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'borrador'"/>

                    <button name="accion_verificar"
                            string="Verificar"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'recibido'"/>

                    <button name="accion_completar"
                            string="Completar"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'verificado'"/>

                    <button name="accion_borrador"
                            string="Regresar a borrador"
                            type="object"
                            invisible="state not in ['recibido', 'verificado']"/>

                    <button name="accion_cancelar"
                            string="Cancelar"
                            type="object"
                            invisible="state not in ['borrador', 'recibido', 'verificado']"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="borrador,recibido,verificado,completado"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="responsable_id"/>
                        </group>

                        <group>
                            <field name="fecha_pedido"/>
                            <field name="fecha_recepcion"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Líneas del pedido">
                            <field name="linea_ids">
                                <list editable="bottom">
                                    <field name="zapato_id"/>
                                    <field name="cantidad_pedida"/>
                                    <field name="cantidad_recibida"/>
                                    <field name="diferencia" readonly="1"/>
                                    <field name="precio_unitario"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                            </field>

                            <group class="oe_subtotal_footer">
                                <field name="total" readonly="1"/>
                            </group>
                        </page>

                        <page string="Observaciones">
                            <field name="notas"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de lista: muestra todos los pedidos en forma de tabla -->
    <record id="view_recepcion_pedido_list" model="ir.ui.view">
        <field name="name">recepcion.pedido.list</field>
        <field name="model">recepcion.pedido</field>
        <field name="arch" type="xml">
            <list string="Recepciones">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="fecha_pedido"/>
                <field name="fecha_recepcion"/>
                <field name="responsable_id"/>
                <field name="total" sum="Total"/>

                <field name="state"
                       decoration-info="state == 'borrador'"
                       decoration-warning="state == 'recibido'"
                       decoration-success="state == 'completado'"
                       decoration-danger="state == 'cancelado'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Vista de búsqueda: filtros y agrupaciones para localizar pedidos -->
    <record id="view_recepcion_pedido_search" model="ir.ui.view">
        <field name="name">recepcion.pedido.search</field>
        <field name="model">recepcion.pedido</field>
        <field name="arch" type="xml">
            <search string="Buscar pedidos">
                <field name="name"/>
                <field name="partner_id"/>

                <filter name="filtro_borrador"
                        string="En borrador"
                        domain="[('state', '=', 'borrador')]"/>

                <filter name="filtro_completado"
                        string="Completados"
                        domain="[('state', '=', 'completado')]"/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_partner"
                            string="Cliente / Proveedor"
                            context="{'group_by': 'partner_id'}"/>

                    <filter name="group_state"
                            string="Estado"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción que abre las vistas anteriores desde el menú -->
    <record id="action_recepcion_pedido" model="ir.actions.act_window">
        <field name="name">Recepción de Pedidos</field>
        <field name="res_model">recepcion.pedido</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_recepcion_pedido_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registre su primera recepción de pedido
            </p>
        </field>
    </record>

</odoo>